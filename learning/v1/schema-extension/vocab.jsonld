  },
  "@graph": [
    {"@id":"learning:","@type":"rdfs:Ontology","rdfs:label":"Beckn Learning Domain Vocabulary","rdfs:comment":"Vocabulary for courses, enrollment, progress, and certificates. Aligned with groclake_learning_manager and L&D/Training frontends.","schema:version":"1.0.0"},
    {"@id":"learning:Course","@type":"rdfs:Class","rdfs:label":"Course","rdfs:comment":"Represents a course or course offering","rdfs:subClassOf":"beckn:Item"},
    {"@id":"learning:LearningCourse","@type":"rdfs:Class","rdfs:label":"Learning Course","rdfs:comment":"Course with learning domain specific attributes","rdfs:subClassOf":"learning:Course"},
    {"@id":"learning:CourseCategory","@type":"rdfs:Class","rdfs:label":"Course Category","rdfs:comment":"Category of the course","schema:enumeration":["technical","soft_skills","certification","degree","workshop","other"]},
    {"@id":"learning:CourseLevel","@type":"rdfs:Class","rdfs:label":"Course Level","rdfs:comment":"Difficulty or audience level","schema:enumeration":["beginner","intermediate","advanced","expert"]},
    {"@id":"learning:CourseType","@type":"rdfs:Class","rdfs:label":"Course Type","rdfs:comment":"Delivery/format of the course","schema:enumeration":["online","offline","hybrid","self_paced","instructor_led"]},
    {"@id":"learning:CourseStatus","@type":"rdfs:Class","rdfs:label":"Course Status","rdfs:comment":"Publication status of the course","schema:enumeration":["draft","open","closed","archived"]},
    {"@id":"learning:EnrollmentStatus","@type":"rdfs:Class","rdfs:label":"Enrollment Status","rdfs:comment":"Status of a course enrollment","schema:enumeration":["pending","confirmed","in_progress","completed","cancelled","failed"]},
    {"@id":"learning:EnrollmentStage","@type":"rdfs:Class","rdfs:label":"Enrollment Stage","rdfs:comment":"Stage in the enrollment lifecycle","schema:enumeration":["applied","enrolled","started","in_progress","assessment","completed"]},
    {"@id":"learning:CertificateType","@type":"rdfs:Class","rdfs:label":"Certificate Type","rdfs:comment":"Type of certificate","schema:enumeration":["completion","participation","achievement","professional"]},
    {"@id":"learning:CertificateStatus","@type":"rdfs:Class","rdfs:label":"Certificate Status","rdfs:comment":"Status of the certificate","schema:enumeration":["issued","revoked","expired"]},
    {"@id":"learning:ContentType","@type":"rdfs:Class","rdfs:label":"Content Type","rdfs:comment":"Type of course content","schema:enumeration":["module","lesson","video","reading","assignment","quiz","project","other"]},
    {"@id":"learning:CompletionStatus","@type":"rdfs:Class","rdfs:label":"Completion Status","rdfs:comment":"Completion status for a content item","schema:enumeration":["not_started","in_progress","completed","skipped"]},
    {"@id":"learning:Location","@type":"rdfs:Class","rdfs:label":"Location","rdfs:comment":"Venue or location for course delivery","rdfs:subClassOf":"schema:Place"},
    {"@id":"learning:Schedule","@type":"rdfs:Class","rdfs:label":"Schedule","rdfs:comment":"Course schedule with dates and sessions","rdfs:subClassOf":"schema:Schedule"},
